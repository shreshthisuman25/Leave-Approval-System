MONGODB_URI=mongodb://localhost:27017/leave-approval-system
SESSION_SECRET=your_session_secret_key_here
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
NODE_ENV=development
CLIENT_URL=http://localhost:3000
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-1.5-flash

# Leave Balance Configuration
# Set to 'true' to skip all leave balance checks globally
SKIP_LEAVE_BALANCE_CHECK=false

# Instant Leave Balance Configuration
SKIP_INSTANT_LEAVE_BALANCE=false
ALLOW_NEGATIVE_INSTANT_LEAVE_BALANCE=false
MAX_NEGATIVE_INSTANT_LEAVE_BALANCE=0

# Per Leave Type Balance Configuration
# Sick Leave
SKIP_SICK_LEAVE_BALANCE=false
ALLOW_NEGATIVE_SICK_BALANCE=false
MAX_NEGATIVE_SICK_BALANCE=0

# Emergency Leave
SKIP_EMERGENCY_LEAVE_BALANCE=false
ALLOW_NEGATIVE_EMERGENCY_BALANCE=false
MAX_NEGATIVE_EMERGENCY_BALANCE=0

# Vacation Leave
SKIP_VACATION_LEAVE_BALANCE=false
ALLOW_NEGATIVE_VACATION_BALANCE=false
MAX_NEGATIVE_VACATION_BALANCE=0

# Personal Leave
SKIP_PERSONAL_LEAVE_BALANCE=false
ALLOW_NEGATIVE_PERSONAL_BALANCE=false
MAX_NEGATIVE_PERSONAL_BALANCE=0

# Maternity Leave
SKIP_MATERNITY_LEAVE_BALANCE=false
ALLOW_NEGATIVE_MATERNITY_BALANCE=false
MAX_NEGATIVE_MATERNITY_BALANCE=0

# Paternity Leave
SKIP_PATERNITY_LEAVE_BALANCE=false
ALLOW_NEGATIVE_PATERNITY_BALANCE=false
MAX_NEGATIVE_PATERNITY_BALANCE=0

# Other Leave
SKIP_OTHER_LEAVE_BALANCE=false
ALLOW_NEGATIVE_OTHER_BALANCE=false
MAX_NEGATIVE_OTHER_BALANCE=0

# Google Calendar API Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5000/api/google/callback
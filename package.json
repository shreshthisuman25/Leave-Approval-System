{
  "name": "leave-approval-system",
  "version": "1.2.2",
  "description": "MERN stack application for leave approval system",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client": "cd client && npm start",
    "server": "nodemon server.js",
    "build": "npm install && cd client && npm install && npm run build",
    "bootstrap": "node bootstrap.js",
    "setup": "node setup-first-user.js",
    "heroku-postbuild": "NPM_CONFIG_PRODUCTION=false npm install --prefix client && npm run build --prefix client"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^2.4.3",
    "connect-mongodb-session": "^3.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "googleapis": "^128.0.0",
    "leave-mailer-bot": "^1.0.0",
    "medical-certificate-validator": "^1.0.0",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "mern",
    "leave",
    "approval",
    "system"
  ],
  "author": "Harsh Jain",
  "license": "MIT"
}
